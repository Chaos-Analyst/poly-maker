# Polymarket Authentication
PK=your_private_key_here
# BROWSER_ADDRESS must be your Polymarket proxy wallet that holds funds (used as the order "funder").
BROWSER_ADDRESS=your_wallet_address_here
# CLOB v2 order-signing type: 1=POLY_PROXY (default), 2=POLY_GNOSIS_SAFE, 3=POLY_1271 (deposit wallet)
# The relayer used for merges follows this too: 1 -> PROXY, 2 -> SAFE.
SIGNATURE_TYPE=1

# Builder API credentials (required for position merging via the Polymarket Relayer API).
# Without these, the bot still runs and trades, but merge_positions() will raise.
BUILDER_API_KEY=your_builder_api_key_here
BUILDER_SECRET=your_builder_secret_here
BUILDER_PASSPHRASE=your_builder_passphrase_here
# Optional override; defaults to https://relayer-v2.polymarket.com
# RELAYER_URL=https://relayer-v2.polymarket.com

# ---- Postgres (market data, summary, risk state) ----
# Read by the bot, updater, and stats. Set it per process to wherever Postgres is:
# use localhost when it runs on this machine, or this host's address from another.
DATABASE_URL=postgresql+psycopg2://poly:poly@localhost:5432/polymaker

# ---- Strategy hyperparameters (was the "Hyperparameters" sheet) ----
# One global set now (the per-market "type" grouping was removed).
# PLACEHOLDERS — copy the real values you were using from the old sheet.
STOP_LOSS_THRESHOLD=-5        # exit if PnL% drops below this (and spread is tight)
SPREAD_THRESHOLD=0.02         # max bid/ask spread (price units) at which a stop-loss exit is allowed
VOLATILITY_THRESHOLD=200      # 3-hour annualized volatility above which we stop buying / risk off
SLEEP_PERIOD=6               # hours to pause buying after a stop-loss
TAKE_PROFIT_THRESHOLD=3       # profit % target above average cost

# ---- Position sizing (was per-market in the "Selected Markets" sheet) ----
# PLACEHOLDERS — start small; this now applies to EVERY discovered market.
TRADE_SIZE=10                 # order-size increment per quote (required)
MAX_SIZE=30                   # max position per side before it only sells
MULTIPLIER=                   # multiplies buy size for assets priced < 0.10; blank = disabled
