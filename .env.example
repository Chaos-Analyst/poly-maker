# Polymarket Authentication
PK=your_private_key_here
# BROWSER_ADDRESS must be your Polymarket proxy wallet that holds funds (used as the order "funder").
BROWSER_ADDRESS=your_wallet_address_here
# CLOB v2 order-signing type: 1=POLY_PROXY (default), 2=POLY_GNOSIS_SAFE, 3=POLY_1271 (deposit wallet)
# The relayer used for merges follows this too: 1 -> PROXY, 2 -> SAFE.
SIGNATURE_TYPE=1

# Builder API credentials (required for position merging via the Polymarket Relayer API).
# Without these, the bot still runs and trades, but merge_positions() will raise.
BUILDER_API_KEY=your_builder_api_key_here
BUILDER_SECRET=your_builder_secret_here
BUILDER_PASSPHRASE=your_builder_passphrase_here
# Optional override; defaults to https://relayer-v2.polymarket.com
# RELAYER_URL=https://relayer-v2.polymarket.com

# ---- Postgres (market data, summary, risk state) ----
# Read by the bot, updater, and stats. Set it per process to wherever Postgres is:
# use localhost when it runs on this machine, or this host's address from another.
DATABASE_URL=postgresql+psycopg2://poly:poly@localhost:5432/polymaker

# ---- Strategy hyperparameters (was the "Hyperparameters" sheet) ----
# One global set now (the per-market "type" grouping was removed).
# PLACEHOLDERS — copy the real values you were using from the old sheet.
STOP_LOSS_THRESHOLD=-5        # exit if PnL% drops below this (and spread is tight)
SPREAD_THRESHOLD=0.02         # max bid/ask spread (price units) at which a stop-loss exit is allowed
VOLATILITY_THRESHOLD=200      # 3-hour annualized volatility above which we stop buying / risk off
SLEEP_PERIOD=6               # hours to pause buying after a stop-loss
TAKE_PROFIT_THRESHOLD=3       # profit % target above average cost

# ---- Behavior switches (defaults preserve the original market-making behavior) ----
# ENABLE_SELLING=false  -> the bot NEVER places a market SELL (no stop-loss, no take-profit).
#                          Positions only shrink by merging YES+NO or at market resolution.
# BUILD_BOTH_SIDES=true -> drop the "don't hold the opposite outcome" guard so the bot
#                          accumulates YES AND NO and merges matched pairs back into collateral.
# Set BOTH (selling off + build both sides) for a delta-neutral, merge-to-flatten reward farmer.
ENABLE_SELLING=true
BUILD_BOTH_SIDES=false
# Delta-neutral knobs (only used when BUILD_BOTH_SIDES=true):
# MAX_IMBALANCE: max shares one side may lead the other before the bot pauses buying the
#   leading side (so both sides stay balanced and mergeable). Blank = fall back to TRADE_SIZE.
# MERGE_COLLATERAL_FLOOR: proactively merge mergeable pairs when free (spendable) collateral
#   drops below this many units. Blank = only merge when an order is rejected for balance.
#   Recommended: set this so the bot recycles before fully exhausting collateral.
MAX_IMBALANCE=
MERGE_COLLATERAL_FLOOR=
# POST_ONLY=true (default): buy orders are maker-only. If a buy would cross the spread and fill as a
# taker (paying the spread, earning no rewards), the API rejects it instead — keeping every fill
# reward-eligible. Set false to allow taker fills. Applies to buys only; sells execute normally.
POST_ONLY=true

# ---- Position sizing (applies to EVERY market in the table) ----
# Order size per quote, in SHARES. Leave BLANK to size each market at its own reward
# min_size (the smallest reward-qualifying order). Set a number to force that fixed size
# everywhere and IGNORE each market's min_size (it will then place orders below the reward
# threshold too — fine for trading, but those orders won't earn rewards).
TRADE_SIZE=
# Max inventory (shares) per side before it stops buying and only sells. Blank = same as
# TRADE_SIZE (hold at most one lot per side).
MAX_SIZE=
MULTIPLIER=                   # multiplies buy size for assets priced < 0.10; blank = disabled

# ---- Market selection (sports-only) ----
# The updater restricts the traded universe to today/live sport GAME markets:
# soccer, singles tennis, NHL, NBA, MLB, and CS2+LoL esports (season-long futures excluded).
# Comma-separated subset of: soccer,tennis,nba,nhl,mlb,esports. Blank = all six.
SPORTS_TAG_SLUGS=
# How many hours ahead a game may resolve and still count as "today" (live games always count).
SPORTS_HORIZON_HOURS=36
# Reward floor: only keep sport markets paying at least this gm_reward_per_100.
MAKER_REWARD=0.75
# Anti-wipe: don't replace the markets table if fewer than this many markets pass (default 1).
MIN_MARKETS_TO_WRITE=1
# Updater refresh interval (seconds). 900 (15m) keeps today's slate fresh as games go live/end.
UPDATE_INTERVAL_SECONDS=900

# ---- Single-market override (optional) ----
# When true, trade ONLY the listed markets, bypassing the sport filter AND the reward floor.
SINGLE_MARKET_ENABLED=false
# Comma-separated 0x-prefixed 64-hex condition ids (required when SINGLE_MARKET_ENABLED=true).
SINGLE_MARKET_CONDITION_IDS=
